@{
    ViewData["Title"] = "Request Sent";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Request Sent</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: #f6fff9;
            font-family: 'Segoe UI', sans-serif;
        }

        .success-card {
            max-width: 430px;
            margin: 70px auto;
            background: white;
            border-radius: 20px;
            padding: 35px;
            text-align: center;
            box-shadow: 0 15px 40px rgba(0,0,0,0.08);
        }

        .check-circle {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: #22c55e;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            color: white;
            font-size: 40px;
        }

        .status-box {
            background: #f3faf6;
            border-radius: 15px;
            padding: 20px;
            margin-top: 25px;
            text-align: left;
            font-size: 14px;
        }

        .status-item {
            display: flex;
            align-items: center;
            margin-bottom: 12px;
        }

        .status-dot {
            width: 10px;
            height: 10px;
            background: #22c55e;
            border-radius: 50%;
            margin-right: 10px;
        }

        .btn-green {
            background: #22c55e;
            color: white;
            border-radius: 30px;
            padding: 10px;
            width: 100%;
            font-weight: 600;
            margin-top: 20px;
        }

        .btn-green:hover {
            background: #16a34a;
        }

        .small-text {
            font-size: 13px;
            color: gray;
        }
    </style>
</head>

<body>

    <div class="success-card">

        <div class="check-circle">✓</div>

        <h4 class="fw-bold">Request Sent!</h4>

        <p class="small-text">
            Your request has been sent to the provider.<br />
            They will review it and get back to you shortly.
        </p>

        <div class="status-box">
            <div class="status-item">
                <div class="status-dot"></div>
                <div>
                    <b>Request Submitted</b><br />
                    <span class="small-text">Today @ViewBag.RequestTime</span>
                </div>
            </div>

            <div class="status-item">
                <div class="status-dot" style="background:#cbd5e1"></div>
                <div>
                    <b>Provider Review</b><br />
                    <span class="small-text">Usually takes 2–4 hours</span>
                </div>
            </div>

            <div class="status-item">
                <div class="status-dot" style="background:#cbd5e1"></div>
                <div>
                    <b>Service Scheduled</b><br />
                    <span class="small-text">Awaiting confirmation</span>
                </div>
            </div>
        </div>

        <a href="/Dashboard/Index" class="btn btn-green">
            Go to Dashboard
        </a>

        <p class="small-text mt-3">Print Receipt</p>

    </div>

</body>
</html>