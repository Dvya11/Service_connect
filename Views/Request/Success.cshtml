@{
    ViewData["Title"] = "Request Sent";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Request Sent</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

    <style>
        body {
            background: #f6fff9;
            font-family: 'Segoe UI', sans-serif;
        }

        /* NAVBAR */
        .navbar-custom {
            background: white;
            padding: 12px 30px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        }

        .brand-logo {
            font-weight: 700;
            font-size: 20px;
            color: #22c55e;
        }

        .profile-btn {
            border: none;
            background: none;
            font-size: 22px;
            color: #333;
        }

        /* SUCCESS CARD */
        .success-card {
            max-width: 430px;
            margin: 70px auto;
            background: white;
            border-radius: 20px;
            padding: 35px;
            text-align: center;
            box-shadow: 0 15px 40px rgba(0,0,0,0.08);
        }

        .check-circle {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: #22c55e;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            color: white;
            font-size: 40px;
        }

        .status-box {
            background: #f3faf6;
            border-radius: 15px;
            padding: 20px;
            margin-top: 25px;
            text-align: left;
            font-size: 14px;
        }

        .status-item {
            display: flex;
            align-items: center;
            margin-bottom: 12px;
        }

        .status-dot {
            width: 10px;
            height: 10px;
            background: #22c55e;
            border-radius: 50%;
            margin-right: 10px;
        }

        .btn-green {
            background: #22c55e;
            color: white;
            border-radius: 30px;
            padding: 10px;
            width: 100%;
            font-weight: 600;
            margin-top: 20px;
        }

        .btn-green:hover {
            background: #16a34a;
        }

        .small-text {
            font-size: 13px;
            color: gray;
        }
    </style>
</head>

<body>

    <!-- ✅ NAVBAR -->
    <nav class="navbar navbar-custom d-flex justify-content-between">
        <div class="brand-logo">
            <i class="fa-solid fa-screwdriver-wrench"></i> Service Connect
        </div>

        <div class="dropdown">
            <button class="profile-btn dropdown-toggle" data-bs-toggle="dropdown">
                <i class="fa-solid fa-user-circle"></i>
            </button>

            <ul class="dropdown-menu dropdown-menu-end">
                <li>
                    <!-- ✅ UPDATED LOGOUT LINK -->
                    <a asp-controller="Service"
                       asp-action="Logout"
                       class="dropdown-item text-danger">
                        <i class="fa-solid fa-right-from-bracket"></i> Logout
                    </a>
                </li>
            </ul>
        </div>
    </nav>

    <!-- ✅ SUCCESS CONTENT -->
    <div class="success-card">

        <div class="check-circle">✓</div>

        <h4 class="fw-bold">Request Sent!</h4>

        <p class="small-text">
            Your request has been sent to the provider.<br />
            They will review it and get back to you shortly.
        </p>

        <div class="status-box">
            <div class="status-item">
                <div class="status-dot"></div>
                <div>
                    <b>Request Submitted</b><br />
                    <span class="small-text">
                        Today @DateTime.Now.ToString("hh:mm tt")
                    </span>
                </div>
            </div>

            <div class="status-item">
                <div class="status-dot" style="background:#cbd5e1"></div>
                <div>
                    <b>Provider Review</b><br />
                    <span class="small-text">Usually takes 2–4 hours</span>
                </div>
            </div>

            <div class="status-item">
                <div class="status-dot" style="background:#cbd5e1"></div>
                <div>
                    <b>Service Scheduled</b><br />
                    <span class="small-text">Awaiting confirmation</span>
                </div>
            </div>
        </div>

        <a href="/Dashboard/Index" class="btn btn-green">
            Go to Dashboard
        </a>

        <p class="small-text mt-3">Print Receipt</p>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>