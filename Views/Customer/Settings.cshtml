@model Service_connect.Models.AccountSettings

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8"/>
<title>Settings</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet"/>

<style>

body{
background:#f5f7f6;
font-family:Segoe UI;
margin:0;
}

/* Sidebar */

.sidebar{
width:240px;
height:100vh;
background:white;
position:fixed;
padding:25px;
border-right:1px solid #eee;
}

.sidebar a{
display:block;
padding:12px;
border-radius:10px;
text-decoration:none;
color:#444;
margin-bottom:10px;
transition:0.3s;
}

.sidebar a:hover{
background:#e6f9ef;
color:#16a34a;
}

/* Active menu green gradient */

.sidebar a.active{
background:linear-gradient(90deg,#16a34a,#22c55e);
color:white;
font-weight:600;
}

/* Main */

.main{
margin-left:240px;
padding:30px;
}

.page-header{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:20px;
}

.card-box{
background:white;
border-radius:18px;
padding:25px;
box-shadow:0 6px 20px rgba(0,0,0,0.05);
}

.profile-img{
width:80px;
height:80px;
border-radius:12px;
background:#f3e0d7;
display:flex;
align-items:center;
justify-content:center;
}

.profile-img i{
font-size:30px;
color:#555;
}

.green-btn{
background:#16a34a;
border:none;
color:white;
padding:8px 18px;
border-radius:20px;
}

.cancel-btn{
background:#eee;
border:none;
padding:8px 18px;
border-radius:20px;
}

.danger{
border:1px solid #f5c2c7;
border-radius:15px;
padding:20px;
background:#fff5f5;
}

</style>
</head>

<body>

<div class="sidebar">

<h5>
<i class="fa-solid fa-bolt text-success"></i>
Service Connect
</h5>

<hr/>

<a href="/Customer/Dashboard">
<i class="fa fa-chart-line"></i> Dashboard
</a>

<a href="/Admin/Profile">
<i class="fa fa-user"></i> Profile
</a>

<a class="active">
<i class="fa fa-gear"></i> Settings
</a>

</div>


<div class="main">

<div class="page-header">

<div>
<small class="text-success">PREFERENCE CENTER</small>
<h3>Settings</h3>
</div>

<div>

<button type="button"
        onclick="location.href='/Customer/Settings'"
        class="cancel-btn">
Cancel
</button>

<button type="submit" form="settingsForm" class="green-btn">
Save Changes
</button>

</div>

</div>


@if(ViewBag.Message != null)
{
<div class="alert alert-success">
@ViewBag.Message
</div>
}


<div class="row">

<div class="col-md-8">

<div class="card-box">

<div class="d-flex justify-content-between mb-3">
<h5>Account Details</h5>
<span class="badge bg-success">VERIFIED ACCOUNT</span>
</div>


<form id="settingsForm" method="post" asp-controller="Customer" asp-action="Settings">

<div class="d-flex mb-4">

<div class="profile-img">
<i class="fa fa-user"></i>
</div>

<div class="ms-3">

<b>Profile Picture</b><br/>

<input type="file" class="form-control mt-2"/>

</div>

</div>


<div class="row">

<div class="col-md-6 mb-3">

<label>Full Name</label>
<input class="form-control" asp-for="FullName"/>

</div>


<div class="col-md-6 mb-3">

<label>Email Address</label>
<input class="form-control" asp-for="Email"/>

</div>


<div class="col-md-6 mb-3">

<label>Professional Title</label>
<input class="form-control" asp-for="Title"/>

</div>


<div class="col-md-6 mb-3">

<label>Country</label>

<select class="form-control" asp-for="Country">
<option>United States</option>
<option>India</option>
<option>Canada</option>
</select>

</div>

</div>

</form>

</div>

</div>


<div class="col-md-4">

<div class="card-box mb-3">

<h6>
<i class="fa fa-shield text-success"></i>
Security
</h6>

<form asp-controller="Account" asp-action="ChangePassword" method="post">

<button type="submit" class="btn btn-light w-100 mt-3">
Change Password
</button>

</form>

</div>


<div class="danger">

<h6 class="text-danger">Danger Zone</h6>

<p class="text-muted">
Permanently delete your account and all associated data.
</p>

<button onclick="location.href='/Customer/DeleteAccount'" class="btn btn-danger">
Delete Account
</button>

</div>

</div>

</div>

</div>

</body>
</html>