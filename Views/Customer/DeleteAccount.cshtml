@{
Layout = null;
}

<!DOCTYPE html>
<html>
<head>

<meta charset="utf-8"/>
<title>Delete Account</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet"/>

<style>

body{
background:#f3f5f4;
font-family:Segoe UI;
display:flex;
justify-content:center;
align-items:center;
height:100vh;
}

.container-box{
width:720px;
background:white;
border-radius:18px;
padding:35px;
box-shadow:0 10px 35px rgba(0,0,0,0.08);
}

.brand{
font-weight:600;
color:#16a34a;
display:flex;
align-items:center;
gap:8px;
}

.warning-box{
border:1px solid #f5c2c7;
background:#fff5f5;
border-radius:14px;
padding:20px;
margin-top:20px;
}

.loss-box{
background:#f5f7f6;
padding:15px;
border-radius:12px;
margin-top:10px;
display:flex;
align-items:center;
gap:10px;
}

.btn-delete{
background:#ef4444;
color:white;
border:none;
padding:10px 20px;
border-radius:20px;
text-decoration:none;
}

.btn-keep{
border:1px solid #16a34a;
color:#16a34a;
background:white;
padding:10px 20px;
border-radius:20px;
}

.footer{
text-align:center;
margin-top:25px;
font-size:12px;
color:#777;
}

</style>

</head>

<body>

<div class="container-box">

<div class="d-flex justify-content-between">

<div class="brand">
<i class="fa-solid fa-bolt"></i>
Service Connect
</div>

<i class="fa fa-times text-muted"></i>

</div>

<div class="mt-4">

<small class="text-danger">
<i class="fa fa-triangle-exclamation"></i>
SECURITY & PRIVACY
</small>

<h3 class="mt-2">Delete Your Account?</h3>

<p class="text-muted">
This action is permanent. Once your account is deleted,
your data cannot be recovered.
</p>

<div class="warning-box">

<b class="text-danger">
<i class="fa fa-circle-exclamation"></i>
Warning: Irreversible Action
</b>

<p class="mt-3 text-muted">WHAT YOU WILL LOSE FOREVER:</p>

<div class="loss-box">
<i class="fa fa-calendar text-danger"></i>
Active Bookings
</div>

<div class="loss-box">
<i class="fa fa-user text-danger"></i>
Provider Connections
</div>

</div>

<div class="mt-4 d-flex gap-3 justify-content-center">

<button type="button" onclick="history.back()" class="btn-keep">
Keep My Account
</button>

<a asp-controller="Home" asp-action="Index" class="btn-delete">
Delete My Account Permanently
</a>

</div>

<div class="footer">
© 2024 Service Connect. Processing this request may take up to 48 hours.
</div>

</div>

</div>

</body>
</html>