@{
    ViewData["Title"] = "Admin Profile";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Admin Profile</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

    <style>
        body {
            background-color: #f4f6f9;
            font-family: 'Segoe UI', sans-serif;
        }

        .sidebar {
            width: 250px;
            height: 100vh;
            background: #fff;
            padding: 20px;
            position: fixed;
            box-shadow: 2px 0 10px rgba(0,0,0,0.05);
        }

        .sidebar a {
            display: block;
            padding: 12px;
            text-decoration: none;
            color: #333;
            border-radius: 8px;
            margin-bottom: 8px;
        }

        .sidebar a:hover {
            background: #e9f7ef;
            color: #28a745;
        }

        .content {
            margin-left: 270px;
            padding: 30px;
        }

        .profile-card {
            background: #fff;
            border-radius: 15px;
            padding: 25px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        }

        .profile-header {
            background: linear-gradient(90deg, #a8e6cf, #dcedc1);
            height: 120px;
            border-radius: 15px;
        }

        .profile-img {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            margin-top: -60px;
            border: 5px solid #fff;
        }

        .logout-btn {
            float: right;
        }
    </style>
</head>
<body>

    <!-- Sidebar -->
    <div class="sidebar">
        <h4 class="mb-4"><i class="fa-solid fa-bolt text-success"></i> Service Connect</h4>

        <a href="/Admin/Dashboard"><i class="fa-solid fa-chart-line"></i> Dashboard</a>
        <a href="/Admin/Profile"><i class="fa-solid fa-user"></i> Profile</a>
        <a href="/Admin/Settings"><i class="fa-solid fa-gear"></i> Settings</a>
        <a href="/Admin/Logout" class="text-danger"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
    </div>

    <!-- Main Content -->
    <div class="content">

        <div class="profile-card">

            <div class="profile-header"></div>

            <div class="text-center">
                <img src="https://i.pravatar.cc/150?img=3" class="profile-img" />
                <h3 class="mt-3">Admin Name</h3>
                <p class="text-muted">admin@serviceconnect.com</p>
            </div>

            <hr />

            <div class="row text-center">
                <div class="col-md-6">
                    <h4 class="text-success">24</h4>
                    <p>Total Users</p>
                </div>

                <div class="col-md-6">
                    <h4 class="text-success">12</h4>
                    <p>Active Services</p>
                </div>
            </div>

        </div>

    </div>

</body>
</html>