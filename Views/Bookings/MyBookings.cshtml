@model List<Service_connect.Models.Booking>
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>

<title>My Bookings</title>

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

body{
margin:0;
font-family:'Segoe UI',sans-serif;
background:#f4f6f5;
}

.dashboard{
display:flex;
}
/* Sidebar */

.sidebar{
width:240px;
background:white;
height:100vh;
border-right:1px solid #e5e5e5;
padding:20px;
}

.logo{
font-size:20px;
font-weight:600;
margin-bottom:30px;
}

/* Sidebar menu */

.sidebar ul{
list-style:none;
padding:0;
}

.sidebar ul li{
margin-bottom:12px;
}

.sidebar ul li a{
text-decoration:none;
color:#444;
display:block;
padding:12px;
border-radius:10px;
transition:0.3s;
}

.sidebar ul li a:hover{
background:#e6f9ef;
color:#16a34a;
}

/* Active menu green */

.sidebar .active a{
background:linear-gradient(90deg,#16a34a,#22c55e);
color:white;
font-weight:600;
border-radius:10px;
}

.logout a{
color:red;
}


/* Main */

.main{
flex:1;
padding:30px;
}

.header{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:20px;
}

.header h1{
margin:0;
font-size:24px;
}

.new-btn{
background:#19c463;
border:none;
padding:12px 22px;
border-radius:25px;
color:white;
font-weight:600;
cursor:pointer;
}

/* Booking list */

.booking-list{
margin-top:20px;
}

/* Booking card */

.booking-card{
background:white;
padding:20px;
border-radius:15px;
display:flex;
align-items:center;
margin-bottom:20px;
box-shadow:0 3px 10px rgba(0,0,0,0.05);
}

.booking-card img{
width:65px;
height:65px;
border-radius:50%;
margin-right:20px;
}

.booking-info h3{
margin:0;
font-size:18px;
}

.booking-info p{
margin:4px 0;
color:gray;
}

.date{
font-size:14px;
color:#777;
}

/* Status */

.status{
font-size:12px;
padding:5px 12px;
border-radius:20px;
margin-left:10px;
}

.pending{
background:#ffe8cc;
color:#ff8c00;
}

.completed{
background:#d4f5df;
color:#0a9d4b;
}

.rejected{
background:#ffd6d6;
color:#d60000;
}

</style>

</head>

<body>

<div class="dashboard">

<!-- Sidebar -->

<div class="sidebar">

<div class="logo">
 Service Connect
</div>

<ul>

<li>
<a asp-controller="Customer" asp-action="Dashboard">
<i class="fa fa-home"></i> Dashboard
</a>
</li>

<li class="active">
<a asp-controller="Bookings" asp-action="MyBookings">
<i class="fa fa-calendar-check"></i> My Bookings
</a>
</li>

<li>
<a asp-controller="Admin" asp-action="Profile">
<i class="fa fa-user"></i> Profile
</a>
</li>

<li>
<a href="#">
<i class="fa fa-gear"></i> Settings
</a>
</li>

<li class="logout">
<a asp-controller="Account" asp-action="Logout">
<i class="fa fa-sign-out-alt"></i> Sign Out
</a>
</li>

</ul>

</div>


<!-- Main Content -->

<div class="main">

<div class="header">

<h1>My Bookings</h1>

<button class="new-btn">
+ New Booking
</button>

</div>

<div class="booking-list">

@foreach (var item in Model)
{
<div class="booking-card">

<img src="/images/img1.png" />

<div class="booking-info">

<h3>
@item.CustomerName

<span class="status @item.Status.ToLower()">
@item.Status
</span>

</h3>

<p>@item.Service</p>

<div class="date">
📅 @item.Date &nbsp;&nbsp; ⏰ @item.Time
</div>

</div>

</div>
}

</div>

</div>

</div>

</body>
</html>