@model List<Service_connect.Models.Booking>
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>My Bookings</title>

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
            background: #f4f6f5;
        }

        .dashboard {
            display: flex;
        }

        .sidebar {
            width: 240px;
            background: white;
            height: 100vh;
            border-right: 1px solid #e5e5e5;
            padding: 20px;
        }

        .logo {
            font-size: 20px;
            font-weight: 600;
            margin-bottom: 30px;
        }

        .sidebar ul {
            list-style: none;
            padding: 0;
        }

        .sidebar ul li {
            margin-bottom: 12px;
        }

        .sidebar ul li a {
            text-decoration: none;
            color: #444;
            display: block;
            padding: 12px;
            border-radius: 10px;
            transition: 0.3s;
        }

        .sidebar ul li a:hover {
            background: #e6f9ef;
            color: #16a34a;
        }

        .sidebar .active a {
            background: linear-gradient(90deg,#16a34a,#22c55e);
            color: white;
            font-weight: 600;
        }

        .logout a {
            color: red;
        }

        .main {
            flex: 1;
            padding: 30px;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .new-btn {
            background: #19c463;
            border: none;
            padding: 10px 20px;
            border-radius: 25px;
            color: white;
            cursor: pointer;
        }

        .booking-card {
            background: white;
            padding: 20px;
            border-radius: 15px;
            display: flex;
            align-items: center;
            margin-top: 20px;
            box-shadow: 0 3px 10px rgba(0,0,0,0.05);
        }

        .booking-card img {
            width: 65px;
            height: 65px;
            border-radius: 50%;
            margin-right: 20px;
        }

        .status {
            font-size: 12px;
            padding: 5px 12px;
            border-radius: 20px;
            margin-left: 10px;
        }

        .pending {
            background: #ffe8cc;
            color: orange;
        }

        .completed {
            background: #d4f5df;
            color: green;
        }

        .rejected {
            background: #ffd6d6;
            color: red;
        }
    </style>
</head>

<body>

<div class="dashboard">

    <!-- Sidebar -->
    <div class="sidebar">
        <div class="logo">Service Connect</div>

        <ul>
            <li>
                <a asp-controller="Customer" asp-action="Dashboard">
                    <i class="fa fa-home"></i> Dashboard
                </a>
            </li>

            <li class="active">
                <a asp-controller="Bookings" asp-action="MyBookings">
                    <i class="fa fa-calendar-check"></i> My Bookings
                </a>
            </li>

            <li>
                <a asp-controller="Admin" asp-action="Profile">
                    <i class="fa fa-user"></i> Profile
                </a>
            </li>

            <li class="logout">
                <a asp-controller="Account" asp-action="Logout">
                    <i class="fa fa-sign-out-alt"></i> Sign Out
                </a>
            </li>
        </ul>
    </div>

    <!-- Main -->
    <div class="main">

        <div class="header">
            <h1>My Bookings</h1>
            <button class="new-btn">+ New Booking</button>
        </div>

        <!-- Booking List -->
        @if (Model != null && Model.Count > 0)
        {
            foreach (var item in Model)
            {
                <div class="booking-card">

                    <img src="/images/img1.png" />

                    <div>
                        <h3>
                            @item.CustomerName
                            <span class="status @(item.Status?.ToLower())">
                                @item.Status
                            </span>
                        </h3>

                        <p>@item.Service</p>

                        <div>
                            📅 @item.Date.ToShortDateString()
                            ⏰ @item.Time
                        </div>
                    </div>

                </div>
            }
        }
        else
        {
            <p>No bookings found.</p>
        }

    </div>

</div>

</body>
</html>