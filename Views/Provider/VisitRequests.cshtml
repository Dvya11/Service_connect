@model List<Service_connect.Models.VisitRequest> 

@{
Layout = null;
}

<!DOCTYPE html>
<html>
<head>

<title>Visit Requests</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<!-- Font Awesome -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

<style>

body{
background:#f4f6f8;
font-family:Segoe UI;
margin:0;
}

/* Sidebar */

.sidebar{
width:240px;
background:white;
height:100vh;
position:fixed;
padding:20px;
border-right:1px solid #e5e5e5;
}

.sidebar h5{
font-weight:600;
margin-bottom:20px;
}

.sidebar a{
display:flex;
align-items:center;
padding:12px;
text-decoration:none;
color:#444;
margin-bottom:10px;
border-radius:10px;
transition:0.3s;
}

.sidebar a i{
margin-right:10px;
}

.sidebar a:hover{
background:#e6f9ef;
color:#16a34a;
}

.sidebar a.active{
background:linear-gradient(90deg,#16a34a,#22c55e);
color:white;
font-weight:600;
}

/* Main */

.main{
margin-left:260px;
padding:30px;
}

.card-box{
background:white;
padding:25px;
border-radius:14px;
margin-bottom:20px;
border:1px solid #eee;
}

.accept{
background:#22c55e;
border:none;
color:white;
padding:10px 25px;
border-radius:25px;
}

.reject{
background:white;
border:1px solid #ef4444;
color:#ef4444;
padding:10px 25px;
border-radius:25px;
margin-left:10px;
}

</style>

</head>

<body>

<!-- SIDEBAR -->

<div class="sidebar">

<h5>
<i class="fa-solid fa-bolt"></i> Service Connect
</h5>

<hr>

<a href="/Provider/Dashboard">
<i class="fa-solid fa-chart-line"></i> Dashboard
</a>

<a href="/Provider/MyJobs" class="active">
<i class="fa-solid fa-calendar-check"></i> My Jobs
</a>

<a href="/Admin/ProviderProfile">
<i class="fa-solid fa-user"></i> Provider Profile
</a>

<a href="/Provider/Settings">
<i class="fa-solid fa-gear"></i> Settings
</a>

<a href="/Account/Logout" style="color:red;">
<i class="fa-solid fa-right-from-bracket"></i> Logout
</a>

</div>


<!-- MAIN -->

<div class="main">

<h3>Visit Requests</h3>

<p>You have @Model.Count requests waiting for response</p>

<div style="margin-bottom:20px;">
<a href="/Admin/ProviderProfile">
View Provider Profile
</a>
</div>

@foreach(var item in Model)
{

<div class="card-box">

<h5>@item.CustomerName</h5>

<p style="color:gray;font-size:14px;">
📍 @item.Address 
</p>

<p>
@item.Description
</p>

@if(item.Status == "Pending")
{
<a href="/Provider/Accept/@item.Id" class="accept">
✔ Accept Request
</a>

<a href="/Provider/Reject/@item.Id" class="reject">
✖ Reject
</a>
}
else
{
<b>Status : @item.Status</b>
}

</div>

}

</div>




</body>
</html>