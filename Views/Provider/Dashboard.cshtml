@{
Layout = null;
}

<!DOCTYPE html>
<html>
<head>

<title>Provider Dashboard</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

<style>

body{
background:#f4f6f8;
font-family:Segoe UI;
}

/* SIDEBAR */

.sidebar{
width:230px;
height:100vh;
background:white;
position:fixed;
padding:20px;
border-right:1px solid #eee;
}

.sidebar a{
display:block;
padding:12px;
margin-bottom:8px;
border-radius:10px;
text-decoration:none;
color:#444;
transition:0.3s;
}

/* Hover */

.sidebar a:hover{
background:#e6f9ef;
color:#16a34a;
}

/* Active menu */

.sidebar a.active{
background:linear-gradient(90deg,#16a34a,#22c55e);
color:white;
font-weight:600;
}

/* MAIN */

.main{
margin-left:230px;
padding:25px;
}

.card-box{
background:white;
padding:18px;
border-radius:12px;
box-shadow:0 5px 20px rgba(0,0,0,0.05);
}

.request-box{
background:white;
padding:15px;
border-radius:12px;
margin-bottom:10px;
border:1px solid #eee;
}

.accept{
background:#16c964;
color:white;
border:none;
padding:5px 15px;
border-radius:20px;
}

.reject{
background:#eee;
border:none;
padding:5px 15px;
border-radius:20px;
}

.profile{
display:flex;
align-items:center;
}

.profile img{
width:40px;
height:40px;
border-radius:50%;
margin-right:10px;
}

</style>

</head>

<body>

<!-- SIDEBAR -->

<div class="sidebar">

<h5>
<i class="fa-solid fa-bolt text-success"></i>
Service Connect
</h5>

<hr>

<a href="/Provider/Dashboard" class="active">
<i class="fa fa-chart-line"></i> Dashboard
</a>

<a href="/Provider/VisitRequests">
<i class="fa fa-briefcase"></i> My Jobs
</a>

<a href="/Admin/Profile">
<i class="fa fa-user"></i> Profile
</a>

<a href="/Customer/Settings">
<i class="fa fa-gear"></i> Settings
</a>

</div>

<!-- MAIN -->

<div class="main">

<div class="d-flex justify-content-between mb-4">

<div>
<h4>Good morning, Bhargav!</h4>
<small>You have 3 jobs scheduled for today.</small>
</div>

<div class="profile">

<img src="https://randomuser.me/api/portraits/men/55.jpg">

<div>
    <h6>Bhargav</h6>
    <h6>Master electonics  </h6>

</div>

</div>

</div>

<!-- stats -->

<div class="row mb-4">

<div class="col-md-6">
<div class="card-box">

<small>AVG. RATING</small>
<h4>@ViewBag.Rating</h4>

</div>
</div>

<div class="col-md-6">
<div class="card-box">

<small>ACTIVE HOURS</small>
<h4>@ViewBag.Hours</h4>

</div>
</div>

</div>

<div class="row">

<!-- In Progress -->

<div class="col-md-8">

<div class="card-box">

<h6>In Progress</h6>

<div class="mt-3">

<b>Full House Rewiring</b><br>
<small>Location: 42 Oak St, North Hills</small>

<div class="progress mt-2">
<div class="progress-bar bg-primary" style="width:65%"></div>
</div>

<small>Estimated Finish: 4:00 PM</small>

</div>

</div>

</div>

<!-- Requests -->

<div class="col-md-4">

<div class="card-box">

<h6>Requests</h6>

<div class="request-box">

<b>Kitchen Light Installation</b><br>
<small>Savan</small>

<div class="mt-2">

<form method="post" asp-controller="Provider" asp-action="AcceptJob">
<button type="submit" class="accept">Accept</button>
</form>

<form method="post" asp-controller="Provider" asp-action="RejectJob">
<button type="submit" class="reject">Reject</button>
</form>

</div>

</div>

<div class="request-box">

<b>electonics </b><br>
<small>Soham</small>

<div class="mt-2">

<form method="post" asp-controller="Provider" asp-action="AcceptJob">
<button type="submit" class="accept">Accept</button>
</form>

<form method="post" asp-controller="Provider" asp-action="RejectJob">
<button type="submit" class="reject">Reject</button>
</form>

</div>

</div>

</div>

<div class="card-box mt-3">

<h6>Recent Activity</h6>

<small>Job Completed</small><br>
<small>Payout Processed</small>

</div>

</div>

</div>

</div>

</body>
</html>