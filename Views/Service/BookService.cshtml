@model Service_connect.Models.BookServiceViewModel

@{
    ViewData["Title"] = "Book Service";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        background: #f4f6f5;
        font-family: 'Segoe UI', sans-serif;
    }

    .service-card {
        background: white;
        padding: 30px;
        border-radius: 15px;
        box-shadow: 0 5px 25px rgba(0,0,0,0.05);
    }

    .map-box {
        height: 200px;
        border-radius: 10px;
        margin-top: 15px;
        overflow: hidden;
    }

    .map-box img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 10px;
    }

    .submit-btn {
        background: #19c463;
        border: none;
        padding: 10px 25px;
        border-radius: 8px;
        color: white;
        font-weight: 600;
    }

    .submit-btn:hover {
        background: #16a956;
    }
</style>

<div class="container mt-5 mb-5">

    <h3 class="mb-2">Book Your Service</h3>

    <!-- ✅ Expert Name Display -->
    @if (ViewBag.ExpertName != null)
    {
        <p class="text-success mb-3">
            Booking service with <strong>@ViewBag.ExpertName</strong>
        </p>
    }

    <!-- ✅ Success Message -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="service-card">

        <!-- ✅ FORM START -->
        <form asp-action="BookService" method="post">
            @Html.AntiForgeryToken()

            <!-- Hidden Expert Name -->
            <input type="hidden" name="ExpertName" value="@ViewBag.ExpertName" />

            <!-- Location -->
            <div class="mb-3">
                <label class="form-label">Service Location</label>
                <input asp-for="Location" class="form-control" placeholder="Enter your address" />
                <span asp-validation-for="Location" class="text-danger"></span>

                <!-- ✅ Map Image Preview -->
                <div class="map-box mt-3">
                    <img src="https://maps.googleapis.com/maps/api/staticmap?center=Mumbai&zoom=13&size=600x300&maptype=roadmap&markers=color:red%7CMumbai"
                         alt="Map Preview">
                </div>
            </div>

            <!-- Description -->
            <div class="mb-3">
                <label class="form-label">Describe the problem</label>
                <textarea asp-for="Description"
                          class="form-control"
                          rows="4"
                          maxlength="500"
                          placeholder="Tell us what needs fixing..."></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <!-- Buttons -->
            <div class="d-flex justify-content-between mt-4">
                <a href="/Service/Index" class="btn btn-light">Back</a>
                <button type="submit" class="submit-btn">
                    Submit Request →
                </button>
            </div>

        </form>
        <!-- ✅ FORM END -->

    </div>

</div>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
}