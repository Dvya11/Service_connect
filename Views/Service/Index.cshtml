<script>
    const categoryFilters = document.querySelectorAll('.category-filter');
    const locationFilters = document.querySelectorAll('.location-filter');
    const items = document.querySelectorAll('.service-item');

    categoryFilters.forEach(f => f.addEventListener('change', filterServices));
    locationFilters.forEach(f => f.addEventListener('change', filterServices));

    function filterServices() {

        const selectedCategories = Array.from(categoryFilters)
            .filter(f => f.checked)
            .map(f => f.value);

        const selectedLocations = Array.from(locationFilters)
            .filter(f => f.checked)
            .map(f => f.value);

        items.forEach(item => {

            const matchCategory = selectedCategories.includes(item.dataset.category);
            const matchLocation = selectedLocations.includes(item.dataset.location);

            if (matchCategory && matchLocation) {
                item.style.display = "block";
            } else {
                item.style.display = "none";
            }

        });
    }

    function resetFilters() {
        categoryFilters.forEach(f => f.checked = true);
        locationFilters.forEach(f => f.checked = true);
        filterServices();
    }

    function requestVisit(name) {
        window.location.href = '/Service/BookService?expertName=' + encodeURIComponent(name);
    }
</script>

<script>
    window.onload = function () {
        let nav = document.querySelector(".navbar-collapse");

        if (nav) {
            let div = document.createElement("div");
            div.className = "nav-extra";

            div.innerHTML = `
                <input type="text" placeholder="Search">
                <button class="btn btn-green btn-sm">Go</button>
                <a href="/Account/Profile">
                    <i class="fa fa-user-circle"></i>
                </a>
            `;

            nav.appendChild(div);  // 🔥 right side me add hoga
        }
    };
</script>