}

<style>
    body {
        background: #f4f6f5;
        font-family: 'Inter', sans-serif;
    }

    /* LOGIN HIDE */
    a[href*="Login"] {
        display: none !important;
    }

.nav-extra {
    display: flex;
    align-items: center;
    gap: 25px;
    margin-left: auto;   /* 🔥 push to right */
}

.nav-extra input {
    border-radius: 20px;
    padding: 5px 10px;
}

.nav-extra i {
    color: #19c463;
    font-size: 20px;
}

    .page-title span {
        color: #19c463;
    }

    .filters-box {
        background: #fff;
        padding: 25px;
        border-radius: 18px;
        box-shadow: 0 4px 18px rgba(0,0,0,0.05);
    }

    .service-card {
        background: #fff;
        border-radius: 18px;
        padding: 22px;
        box-shadow: 0 4px 18px rgba(0,0,0,0.05);
        transition: 0.3s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .service-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    }

    .pro-img {
        height: 70px;
        width: 70px;
        border-radius: 50%;
        object-fit: cover;
    }

    .badge-category {
        font-size: 11px;
        padding: 5px 12px;
        border-radius: 20px;
        font-weight: 600;
        background: #eafff3;
        color: #19c463;
        display: inline-block;
        margin-bottom: 4px;
    }

    .rating {
        font-size: 13px;
        color: #f4b400;
        font-weight: 600;
    }

    .btn-green {
        background: #19c463;
        border: none;
        padding: 9px 22px;
        border-radius: 25px;
        font-size: 14px;
        color: white;
        transition: 0.3s;
    }

    .btn-green:hover {
        background: #149f52;
        transform: scale(1.05);
    }

    .text-muted-small {
        font-size: 13px;
        color: #777;
    }
</style>



