@{
    ViewData["Title"] = "Services";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        background-color: #f3f5f4;
        font-family: 'Inter', sans-serif;
    }

    .btn-green {
        background-color: #19c463;
        color: white;
        border-radius: 30px;
        padding: 6px 20px;
    }

    .btn-green:hover {
        background-color: #13a651;
        color: white;
    }

    /* LOGIN HIDE */
    a[href*="Login"] {
        display: none !important;
    }

    /* HERO */
    .hero-section {
        padding: 70px 20px;
        text-align: center;
    }

    .search-box {
        max-width: 600px;
        margin: 25px auto;
        display: flex;
        gap: 10px;
    }

    /* CARDS */
    .service-card {
        border-radius: 20px;
        padding: 20px;
        transition: 0.3s ease;
    }

    .service-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.08);
    }

    .service-card img {
        height: 180px;
        object-fit: cover;
        border-radius: 12px;
        margin-bottom: 15px;
    }

    footer {
        margin-top: 60px;
        background: white;
        padding: 40px 0;
        border-top: 1px solid #eee;
    }
</style>

<!-- HERO -->
<div class="hero-section">
    <h1 class="fw-bold">Expert Help, Just a Click Away</h1>
    <p class="text-muted mt-2">
        Choose from verified professional services for your home needs.
    </p>

    <div class="search-box">
        <input type="text" id="searchInput" class="form-control rounded-pill p-3"
               placeholder="Search service (plumber, electrician, carpenter)">
        <button onclick="searchService()" class="btn btn-green px-4">Search</button>
    </div>
</div>

<!-- SERVICES -->
<div class="container">
    <div class="row g-4 justify-content-center">

        <!-- Plumber -->
        <div class="col-md-4 service-item">
            <div class="card service-card shadow-sm">
                <div class="card-body text-center">
                    <img src="/images/Plumbing.png" class="img-fluid" />
                    <h5 class="service-title">Plumber</h5>
                    <p class="text-muted">Pipe leaks, bathroom fittings, water repairs.</p>

                    <a asp-controller="Service"
                       asp-action="Index"
                       asp-route-category="Plumber"
                       class="btn btn-green mt-3 px-4">
                        Find Experts
                    </a>
                </div>
            </div>
        </div>

        <!-- Electrician -->
        <div class="col-md-4 service-item">
            <div class="card service-card shadow-sm">
                <div class="card-body text-center">
                    <img src="/images/Electrical.png" class="img-fluid" />
                    <h5 class="service-title">Electrician</h5>
                    <p class="text-muted">Wiring, lighting, electrical maintenance.</p>

                    <a asp-controller="Service"
                       asp-action="Index"
                       asp-route-category="Electrician"
                       class="btn btn-green mt-3 px-4">
                        Find Experts
                    </a>
                </div>
            </div>
        </div>

        <!-- Carpenter -->
        <div class="col-md-4 service-item">
            <div class="card service-card shadow-sm">
                <div class="card-body text-center">
                    <img src="/images/Carpentry.png" class="img-fluid" />
                    <h5 class="service-title">Carpenter</h5>
                    <p class="text-muted">Furniture repair, woodwork and custom design.</p>

                    <a asp-controller="Service"
                       asp-action="Index"
                       asp-route-category="Carpenter"
                       class="btn btn-green mt-3 px-4">
                        Find Experts
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- FOOTER -->
<footer>
    <div class="container text-center">
        <p class="text-muted mb-0">© 2026 ServiceConnect. All rights reserved.</p>
    </div>
</footer>

<script>
    function searchService() {
        let input = document.getElementById("searchInput").value.toLowerCase();
        let services = document.getElementsByClassName("service-item");

        for (let i = 0; i < services.length; i++) {
            let title = services[i].querySelector(".service-title").innerText.toLowerCase();
            services[i].style.display = title.includes(input) ? "block" : "none";
        }
    }
</script>