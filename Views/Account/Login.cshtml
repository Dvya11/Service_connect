@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Service Connect - Login</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:'Poppins',sans-serif;
        }

        body{
            height:100vh;
            display:flex;
            align-items:center;
            justify-content:center;
            background:#f4f6f5;
        }

        .container{
            text-align:center;
        }

        .logo{
            margin-bottom:20px;
        }

        .logo img{
            width:40px;
        }

        .logo h2{
            font-size:18px;
            margin-top:5px;
            font-weight:600;
        }

        .card{
            width:360px;
            background:white;
            padding:30px;
            border-radius:12px;
            box-shadow:0 5px 15px rgba(0,0,0,0.1);
        }

        .card h3{
            text-align:left;
            font-size:18px;
            margin-bottom:5px;
        }

        .card p{
            text-align:left;
            font-size:12px;
            color:gray;
            margin-bottom:20px;
        }

        .form-group{
            text-align:left;
            margin-bottom:15px;
        }

        label{
            font-size:12px;
            font-weight:500;
        }

        input{
            width:100%;
            padding:10px;
            margin-top:5px;
            border-radius:8px;
            border:1px solid #ddd;
            font-size:13px;
        }

        .password-row{
            display:flex;
            justify-content:space-between;
            align-items:center;
        }

        .forgot{
            font-size:11px;
            color:#18c964;
            text-decoration:none;
        }

        .remember{
            display:flex;
            align-items:center;
            font-size:12px;
            margin:10px 0;
        }

        .remember input{
            width:auto;
            margin-right:6px;
        }

        .login-btn{
            width:100%;
            padding:12px;
            border:none;
            border-radius:8px;
            background:#18c964;
            color:white;
            font-weight:500;
            cursor:pointer;
            margin-top:10px;
        }

        .login-btn:hover{
            background:#14b357;
        }

        .footer{
            margin-top:15px;
            font-size:12px;
            color:gray;
        }

        .footer a{
            color:#18c964;
            text-decoration:none;
        }

        .success{
            color:green;
            margin-top:10px;
            font-size:13px;
        }

        .error{
            color:red;
            margin-top:10px;
            font-size:13px;
        }

    </style>

</head>

<body>

<div class="container">

    <div class="logo">
        <img src="/images/Background+Shadow.png">
        <h2>Service Connect</h2>
    </div>

    <div class="card">

        <h3>Welcome back!</h3>
        <p>Please enter your details to sign in.</p>

        <!-- FORM START -->
        <form asp-controller="Account" asp-action="Login" method="post">

            <div class="form-group">
                <label>Email Address</label>
                <input type="email" name="email" placeholder="Enter Your Email" required>
            </div>

            <div class="form-group">
                <div class="password-row">
                    <label>Password</label>
                </div>
                <input type="password" name="password" placeholder="********" required>
            </div>

            <div class="remember">
                <input type="checkbox"> Remember me
            </div>

            <button type="submit" class="login-btn">Login</button>

        </form>
        <!-- FORM END -->


        <!-- SUCCESS MESSAGE -->
        @if (TempData["Success"] != null)
        {
            <p class="success">@TempData["Success"]</p>
        }

        <!-- ERROR MESSAGE -->
        @if (ViewBag.Error != null)
        {
            <p class="error">@ViewBag.Error</p>
        }

    </div>

    <div class="footer">
        Don’t have an account?
        <a asp-controller="Account" asp-action="Register">Sign up</a>
    </div>

</div>

</body>
</html>