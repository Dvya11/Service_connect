@model Service_center.Models.ChangePasswordViewModel

@{
    ViewData["Title"] = "Change Password";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Poppins&display=swap" rel="stylesheet">

<style>

body{
    background:#f4f6f8;
    font-family:Poppins;
}

.container-box{
    width:420px;
    margin:80px auto;
    background:#fff;
    padding:35px;
    border-radius:10px;
    box-shadow:0 4px 15px rgba(0,0,0,0.08);
}

.title{
    font-size:22px;
    font-weight:600;
    margin-bottom:10px;
}

.subtitle{
    font-size:14px;
    color:#777;
    margin-bottom:25px;
}

.form-group{
    margin-bottom:18px;
}

label{
    font-weight:500;
    font-size:14px;
}

input{
    width:100%;
    padding:12px;
    margin-top:5px;
    border-radius:6px;
    border:1px solid #ddd;
}

.strength{
    height:6px;
    background:#eee;
    margin-top:8px;
    border-radius:6px;
}

.strength-bar{
    width:70%;
    height:6px;
    background:#22c55e;
    border-radius:6px;
}

.requirements{
    background:#f1f8f3;
    padding:12px;
    border-radius:6px;
    font-size:13px;
    margin-top:10px;
}

.update-btn{
    width:100%;
    padding:12px;
    background:#16a34a;
    color:white;
    border:none;
    border-radius:8px;
    font-weight:600;
    margin-top:15px;
}

.cancel-btn{
    width:100%;
    padding:12px;
    margin-top:10px;
    border:1px solid #ccc;
    background:#fff;
    border-radius:8px;
}

</style>

<div class="container-box">

<div class="title">Update Your Password</div>

<div class="subtitle">
Ensure your account stays secure by using a strong password.
</div>

<form asp-controller="Account" asp-action="ChangePassword" method="post">

<div class="form-group">
<label>Current Password</label>
<input asp-for="CurrentPassword" type="password" class="form-control"/>
</div>

<div class="form-group">
<label>New Password</label>
<input asp-for="NewPassword" type="password" class="form-control"/>

<div class="strength">
<div class="strength-bar"></div>
</div>

</div>

<div class="form-group">
<label>Confirm New Password</label>
<input asp-for="ConfirmPassword" type="password" class="form-control"/>
</div>

<div class="requirements">
✔ At least 8 characters <br>
✔ One uppercase and one lowercase letter <br>
✔ One number or special character
</div>

<button type="submit" class="update-btn">
Update Password
</button>

<button type="button"
        onclick="location.href='/Customer/Settings'"
        class="cancel-btn">
Cancel
</button>

</form>

</div>