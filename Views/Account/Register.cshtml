@{
    ViewData["Title"] = "Register";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Create Account - Service Connect</title>

    <style>
        body {
            margin: 0;
            background: #f3f5f4;
            font-family: 'Segoe UI', sans-serif;
        }

        .wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            width: 1000px;
            background: white;
            border-radius: 16px;
            display: flex;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        }

        /* LEFT */
        .left {
            width: 45%;
            background: linear-gradient(135deg,#1e3c72,#2a5298);
            color: white;
            padding: 50px;
            position: relative;
        }

        .left h1 {
            font-size: 32px;
            margin-bottom: 15px;
        }

        .left p {
            opacity: 0.9;
        }

        .badge {
            position: absolute;
            bottom: 40px;
            display: flex;
            gap: 15px;
        }

        .badge div {
            background: rgba(255,255,255,0.15);
            padding: 10px 18px;
            border-radius: 12px;
            font-size: 14px;
        }

        /* RIGHT */
        .right {
            width: 55%;
            padding: 40px;
        }

        h2 {
            margin: 0;
        }

        .subtitle {
            color: #666;
            margin-bottom: 20px;
        }

        .role {
            display: flex;
            gap: 15px;
            margin-bottom: 20px;
        }

        .role label {
            flex: 1;
            border: 2px solid #ddd;
            border-radius: 12px;
            padding: 12px;
            text-align: center;
            cursor: pointer;
        }

        .role input {
            display: none;
        }

        .role input:checked + span {
            border-color: #19c463;
            background: #e9fff4;
            color: #19c463;
        }

        .row {
            display: flex;
            gap: 15px;
        }

        input, select {
            width: 100%;
            padding: 12px;
            border-radius: 10px;
            border: 1px solid #ddd;
            margin-bottom: 15px;
        }

        .categories {
            display: flex;
            gap: 10px;
            margin-bottom: 15px;
        }

        .categories label {
            flex: 1;
            border: 1px solid #ddd;
            border-radius: 10px;
            padding: 10px;
            text-align: center;
            cursor: pointer;
        }

        .categories input {
            display: none;
        }

        .categories input:checked + span {
            border-color: #19c463;
            background: #e9fff4;
            color: #19c463;
        }

        button {
            width: 100%;
            padding: 14px;
            background: #19c463;
            color: white;
            border: none;
            border-radius: 30px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
        }

        .error {
            background: #ffe6e6;
            color: red;
            padding: 8px;
            border-radius: 8px;
            margin-bottom: 10px;
        }
    </style>
</head>

<body>

<div class="wrapper">
    <div class="card">

        <!-- LEFT PANEL -->
        <div class="left">
            <h1>Find the perfect expert for your next project.</h1>
            <p>Join over 50,000 professionals and customers connecting every day.</p>

            <div class="badge">
                <div>✔ Verified Experts</div>
                <div>✔ Secure Payments</div>
            </div>
        </div>

        <!-- RIGHT PANEL -->
        <div class="right">
            <h2>Create an account</h2>
            <p class="subtitle">Step into the future of local services</p>

            @if (ViewBag.Error != null)
            {
                <div class="error">@ViewBag.Error</div>
            }

            <form method="post">

                <!-- Role -->
                <div class="role">
                    <label>
                        <input type="radio" name="userType" value="Customer" checked />
                        <span>Customer</span>
                    </label>
                    <label>
                        <input type="radio" name="userType" value="Provider" />
                        <span>Provider</span>
                    </label>
                </div>

                <div class="row">
                    <input name="firstName" placeholder="First Name" />
                    <input name="lastName" placeholder="Last Name" />
                </div>

                <input name="email" placeholder="Email Address" />

                <!-- Category -->
                <div class="categories">
                    <label>
                        <input type="radio" name="category" value="Plumber" />
                        <span>Plumber</span>
                    </label>
                    <label>
                        <input type="radio" name="category" value="Electrician" />
                        <span>Electrician</span>
                    </label>
                    <label>
                        <input type="radio" name="category" value="Carpenter" />
                        <span>Carpenter</span>
                    </label>
                </div>

                <select name="experience">
                    <option>Less than 1 year</option>
                    <option>1 - 3 years</option>
                    <option>3 - 5 years</option>
                    <option>5+ years</option>
                </select>

                <input type="password" name="password" placeholder="Password" />

                <button type="submit">Create Free Account</button>

            </form>
        </div>

    </div>
</div>

</body>
</html>