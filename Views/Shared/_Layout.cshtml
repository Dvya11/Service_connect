<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>ServiceConnect</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

    <!-- FontAwesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Your CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body style="font-family: 'Inter', sans-serif; background-color:#f3f5f4;">

    <!-- ✅ NAVBAR START -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top">
        <div class="container">

            <!-- Logo -->
            <a class="navbar-brand fw-bold text-success" asp-controller="Home" asp-action="Index">
                <i class="fa-solid fa-screwdriver-wrench me-2"></i>
                Service Connect
            </a>

            <!-- Toggle Button -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Center Menu -->
            <div class="collapse navbar-collapse justify-content-center" id="navbarNav">
                <ul class="navbar-nav">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            Home
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Service"
                           asp-action="Service">
                            Services
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#">
                            My Bookings
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#">
                            About
                        </a>
                    </li>

                </ul>
            </div>

            <!-- ✅ RIGHT SIDE (Login OR Profile) -->
            @if (!(ViewData["HideLogin"] as bool? ?? false))
            {
                <!-- 🔹 Login Button -->
                <div class="d-flex">
                    <a asp-controller="Account" asp-action="Login"
                       class="btn btn-success rounded-pill px-4">
                        Login
                    </a>
                </div>
            }
            else
            {
                <!-- 🔹 Profile Icon with Dropdown -->
                <div class="dropdown">
                    <a class="d-flex align-items-center text-decoration-none dropdown-toggle"
                       href="#"
                       id="profileDropdown"
                       data-bs-toggle="dropdown"
                       aria-expanded="false">

                        <div style="width:42px;height:42px;
                                    background:#19c463;
                                    border-radius:50%;
                                    display:flex;
                                    align-items:center;
                                    justify-content:center;
                                    color:white;
                                    font-size:18px;">
                            <i class="fa-solid fa-user"></i>
                        </div>

                    </a>

                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2"
                        aria-labelledby="profileDropdown"
                        style="border-radius:12px; min-width:180px;">

                        <li>
                            <a class="dropdown-item" href="#">
                                <i class="fa-solid fa-user me-2 text-success"></i>
                                My Profile
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item" href="#">
                                <i class="fa-solid fa-calendar-check me-2 text-success"></i>
                                My Bookings
                            </a>
                        </li>

                        <li><hr class="dropdown-divider"></li>

                        <li>
                            <a class="dropdown-item text-danger"
                               asp-controller="Account"
                               asp-action="Logout">
                                <i class="fa-solid fa-right-from-bracket me-2"></i>
                                Logout
                            </a>
                        </li>

                    </ul>
                </div>
            }

        </div>
    </nav>
    <!-- ✅ NAVBAR END -->

    <!-- Page Content -->
    <div class="container-fluid p-0">
        @RenderBody()
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>